# ── Home Assistant ───────────────────────────────────────────────────────────
HA_URL=http://192.168.3.155:8123
HA_TOKEN=your_long_lived_token_here
ENTITY_ID=light.luz

# ── Sync behaviour ───────────────────────────────────────────────────────────
# How often (in seconds) the script checks for light-setting changes.
# Lower values = smoother transitions, higher CPU/network usage.
POLL_INTERVAL=1.0

# HA transition time (seconds) for each light command – creates smooth fades.
TRANSITION_TIME=1

# ── Default / reset state (FR04) ─────────────────────────────────────────────
# State the bulb returns to when the game exits or the script is stopped.
DEFAULT_BRIGHTNESS=255        # 0–255
DEFAULT_COLOR_TEMP_K=4000     # Kelvin (warm white 2700K … cool white 6500K)

